# TaskForge root .gitignore

# Environment Variables
.env
.env.local
.env.development
.env.production
*.env
backend/.env
frontend/.env

# Dependencies
node_modules/
.venv/
venv/
env/
ENV/
build/
dist/
frontend/node_modules/
frontend/dist/
backend/.venv/

# Python
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
db.sqlite3
db.sqlite3-journal

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Static & Media (Typically generated or uploaded)
backend/staticfiles/
backend/media/

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Misc
.cache/
.npm/
.eslintcache
